NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
CRON_SECRET=

# Canonical site URL. Vercel auto-populates VERCEL_PROJECT_PRODUCTION_URL on
# production builds, so this is only needed for custom domains or local prod.
# e.g. https://hantavirus-tracker.com
NEXT_PUBLIC_SITE_URL=

# Per-IP rate-limit salt. Hashes raw IPs before they hit the rate_limits
# table so DB dumps never reveal source IPs. Set to any long random string
# in production; rotating it invalidates in-flight rate windows (fine).
RATE_LIMIT_SALT=
